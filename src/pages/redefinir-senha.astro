---
import BaseLayout from '~/layouts/BaseLayout.astro';
import StoreBadges from '~/components/StoreBadges.astro';

// As credenciais públicas do Supabase (anon) podem ficar no client.
// Mesmas usadas no app mobile (.env do app).
const SUPABASE_URL = 'https://uktcchvnjxflrukuebgd.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_z-wtqy775p_u22Zd0Q1wDg_CfN0vjJY';
---
<BaseLayout
  title="Redefinir senha"
  description="Crie uma nova senha para sua conta iFishing."
  noindex={true}
>
  <section class="bg-gradient-to-b from-brand-light to-white">
    <div class="container-page py-20 lg:py-28">
      <div class="max-w-md mx-auto">

        {/* Estado 1 — Formulário (visível por padrão) */}
        <div id="form-state" class="rounded-card border border-surface-border bg-white p-8 shadow-card">
          <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-brand text-white shadow-card">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>

          <h1 class="text-3xl text-ink mb-2">Nova senha</h1>
          <p class="text-sm text-ink-muted mb-6">
            Defina uma nova senha para sua conta iFishing. Use pelo menos 6 caracteres.
          </p>

          <form id="reset-form" class="space-y-4">
            <div>
              <label for="password" class="block text-xs font-bold text-ink-muted uppercase tracking-wider mb-1.5">
                Nova senha
              </label>
              <div class="relative">
                <input
                  id="password"
                  type="password"
                  required
                  minlength="6"
                  autocomplete="new-password"
                  placeholder="Mínimo 6 caracteres"
                  class="w-full rounded-lg border border-surface-border bg-surface-soft px-4 py-3 pr-12 text-ink outline-none focus:border-brand focus:ring-2 focus:ring-brand/20"
                />
                <button
                  type="button"
                  id="toggle-pwd"
                  aria-label="Mostrar senha"
                  class="absolute inset-y-0 right-0 flex items-center pr-3 text-ink-muted hover:text-ink"
                >
                  <svg id="eye-show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg id="eye-hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 hidden">
                    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                    <line x1="2" x2="22" y1="2" y2="22"/>
                  </svg>
                </button>
              </div>
              <p class="mt-2 text-xs text-ink-muted">Toque no <span class="inline-block align-middle">👁️</span> ao lado pra ver o que você digitou e evitar erros.</p>
            </div>

            <div id="form-error" class="hidden rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"></div>

            <button
              id="submit-btn"
              type="submit"
              class="w-full rounded-lg bg-brand hover:bg-brand-dark text-white font-bold py-3.5 transition disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Salvar nova senha
            </button>
          </form>
        </div>

        {/* Estado 2 — Sucesso (oculto por padrão) */}
        <div id="success-state" class="hidden rounded-card border border-surface-border bg-white p-8 shadow-card text-center">
          <div class="mx-auto mb-6 inline-flex h-20 w-20 items-center justify-center rounded-full bg-brand text-white shadow-card">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>

          <h1 class="text-3xl text-ink">Senha alterada!</h1>
          <p class="mt-4 text-ink-muted">
            Sua senha foi atualizada com sucesso. Agora é só voltar pro app e fazer login com a nova senha.
          </p>

          <div class="mt-8">
            <StoreBadges align="center" />
          </div>
        </div>

        {/* Estado 3 — Link inválido / expirado (oculto por padrão) */}
        <div id="error-state" class="hidden rounded-card border border-surface-border bg-white p-8 shadow-card text-center">
          <div class="mx-auto mb-6 inline-flex h-20 w-20 items-center justify-center rounded-full bg-red-100 text-red-600">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" x2="12" y1="8" y2="12"/>
              <line x1="12" x2="12.01" y1="16" y2="16"/>
            </svg>
          </div>

          <h1 class="text-3xl text-ink">Link inválido</h1>
          <p id="error-message" class="mt-4 text-ink-muted">
            Este link de recuperação expirou ou já foi usado. Solicite um novo no app iFishing.
          </p>

          <p class="mt-6 text-sm text-ink-muted">
            Está com problemas?{' '}
            <a href="/contato" class="text-brand-dark font-semibold underline">Fale com a gente</a>.
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  // Carrega o supabase-js via CDN (evita adicionar dependência ao bundle)
  const script = document.createElement('script');
  script.type = 'module';
  script.textContent = `
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const supabase = createClient(${JSON.stringify(SUPABASE_URL)}, ${JSON.stringify(SUPABASE_ANON_KEY)}, {
      auth: { detectSessionInUrl: false, persistSession: false },
    });

    const formState = document.getElementById('form-state');
    const successState = document.getElementById('success-state');
    const errorState = document.getElementById('error-state');
    const errorMessage = document.getElementById('error-message');
    const form = document.getElementById('reset-form');
    const submitBtn = document.getElementById('submit-btn');
    const formError = document.getElementById('form-error');
    const pwd1 = document.getElementById('password');
    const togglePwd = document.getElementById('toggle-pwd');
    const eyeShow = document.getElementById('eye-show');
    const eyeHide = document.getElementById('eye-hide');

    // Toggle pra mostrar/esconder senha — evita erro de digitação
    togglePwd.addEventListener('click', () => {
      const isPwd = pwd1.type === 'password';
      pwd1.type = isPwd ? 'text' : 'password';
      eyeShow.classList.toggle('hidden', isPwd);
      eyeHide.classList.toggle('hidden', !isPwd);
      togglePwd.setAttribute('aria-label', isPwd ? 'Esconder senha' : 'Mostrar senha');
    });

    function showError(msg) {
      formError.textContent = msg;
      formError.classList.remove('hidden');
    }

    function clearError() {
      formError.textContent = '';
      formError.classList.add('hidden');
    }

    function showInvalidLink(msg) {
      formState.classList.add('hidden');
      errorState.classList.remove('hidden');
      if (msg) errorMessage.textContent = msg;
    }

    // Supabase envia o token via URL hash: #access_token=...&type=recovery
    async function bootstrap() {
      const hash = window.location.hash.startsWith('#')
        ? window.location.hash.slice(1)
        : '';
      const params = new URLSearchParams(hash);
      const accessToken = params.get('access_token');
      const refreshToken = params.get('refresh_token');
      const type = params.get('type');
      const errorCode = params.get('error_code');
      const errorDesc = params.get('error_description');

      if (errorCode || errorDesc) {
        showInvalidLink(decodeURIComponent(errorDesc || 'Link expirado.'));
        return;
      }

      if (!accessToken || type !== 'recovery') {
        showInvalidLink();
        return;
      }

      // Cria sessão temporária só pra permitir o updateUser
      const { error } = await supabase.auth.setSession({
        access_token: accessToken,
        refresh_token: refreshToken || '',
      });

      if (error) {
        showInvalidLink('Não foi possível validar o link. Solicite um novo no app.');
        return;
      }
    }

    bootstrap();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearError();

      const p1 = pwd1.value;

      if (p1.length < 6) {
        showError('A senha precisa ter pelo menos 6 caracteres.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Salvando...';

      const { error } = await supabase.auth.updateUser({ password: p1 });

      if (error) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Salvar nova senha';
        showError('Erro ao salvar: ' + (error.message || 'tente novamente.'));
        return;
      }

      // Encerra a sessão temporária — usuário precisa logar de novo no app
      await supabase.auth.signOut();

      formState.classList.add('hidden');
      successState.classList.remove('hidden');
    });
  `;
  document.head.appendChild(script);
</script>
