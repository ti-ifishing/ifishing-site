---
import BaseLayout from '~/layouts/BaseLayout.astro';
import StoreBadges from '~/components/StoreBadges.astro';
import { SITE } from '~/lib/site';

const screenshots: Array<{ src: string; alt: string; caption: string }> = [
  { src: '/screen-busca.png', alt: 'Tela de busca de guias no iFishing', caption: 'Lista de guias' },
  { src: '/screen-busca2.png', alt: 'Mapa do Brasil com pins de guias no iFishing', caption: 'Mapa do Brasil' },
  { src: '/screen-guia.png', alt: 'Tela de perfil do guia no iFishing', caption: 'Perfil do guia' },
  { src: '/screen-chat.png', alt: 'Tela de chat entre pescador e guia no iFishing', caption: 'Chat' },
  { src: '/screen-calendario.png', alt: 'Tela de calendário e reserva no iFishing', caption: 'Calendário' },
  { src: '/screen-avaliacoes.png', alt: 'Tela de avaliação pós-pescaria no iFishing', caption: 'Avaliação' },
];
---
<BaseLayout
  title="Baixar o iFishing"
  description="Baixe o iFishing na App Store e no Google Play. App para conectar pescadores e guias em todo o Brasil."
>
  <section class="bg-gradient-to-b from-brand-light to-white">
    <div class="container-page py-16 lg:py-20 text-center">
      <h1 class="text-4xl sm:text-5xl text-ink">Baixe o iFishing</h1>
      <p class="mt-3 max-w-xl mx-auto text-lg text-ink-muted">
        Disponível pra iPhone e Android. Crie sua conta em menos de um minuto e veja os guias de pesca disponíveis na sua região.
      </p>
      <div class="mt-8 flex justify-center"><StoreBadges align="center" /></div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-2xl mx-auto">
        <div class="rounded-card border border-surface-border bg-white p-6">
          <p class="text-sm font-semibold text-ink-muted uppercase tracking-wider">iPhone</p>
          <p class="mt-2 text-sm text-ink-muted">Aponte a câmera pro QR code</p>
          <img src="/qr-appstore.png" alt="QR code para baixar o iFishing na App Store" width="160" height="160" class="mt-4 mx-auto h-40 w-40 rounded-lg bg-white p-2 ring-1 ring-surface-border" />
          <a class="mt-4 inline-block text-brand-dark text-sm font-semibold" href={SITE.app.appStoreUrl} target="_blank" rel="noopener">Abrir na App Store →</a>
        </div>
        <div class="rounded-card border border-surface-border bg-white p-6">
          <p class="text-sm font-semibold text-ink-muted uppercase tracking-wider">Android</p>
          <p class="mt-2 text-sm text-ink-muted">Aponte a câmera pro QR code</p>
          <img src="/qr-playstore.png" alt="QR code para baixar o iFishing no Google Play" width="160" height="160" class="mt-4 mx-auto h-40 w-40 rounded-lg bg-white p-2 ring-1 ring-surface-border" />
          <a class="mt-4 inline-block text-brand-dark text-sm font-semibold" href={SITE.app.playStoreUrl} target="_blank" rel="noopener">Abrir no Google Play →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <h2 class="text-3xl text-ink">Por dentro do app</h2>
    <p class="mt-3 max-w-2xl text-ink-muted">Uma volta rápida pelas telas principais do iFishing.</p>
    <div class="mt-8 grid gap-6 sm:gap-8 grid-cols-2 sm:grid-cols-3 lg:grid-cols-6">
      {screenshots.map((s) => (
        <figure class="flex flex-col items-center">
          <div class="relative w-full rounded-[1.75rem] bg-ink p-1.5 shadow-card">
            <img
              src={s.src}
              alt={s.alt}
              loading="lazy"
              decoding="async"
              class="w-full rounded-[1.4rem]"
            />
          </div>
          <figcaption class="mt-3 text-sm font-medium text-ink-muted">{s.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>
