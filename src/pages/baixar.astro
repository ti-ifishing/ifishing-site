---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/lib/site';

const screenshots: Array<{ src: string; alt: string; caption: string }> = [
  { src: '/screen-busca.png', alt: 'Tela de busca de guias no iFishing', caption: 'Lista de guias' },
  { src: '/screen-busca2.png', alt: 'Mapa do Brasil com pins de guias no iFishing', caption: 'Mapa do Brasil' },
  { src: '/screen-guia.png', alt: 'Tela de perfil do guia no iFishing', caption: 'Perfil do guia' },
  { src: '/screen-chat.png', alt: 'Tela de chat entre pescador e guia no iFishing', caption: 'Chat' },
  { src: '/screen-calendario.png', alt: 'Tela de calendário e reserva no iFishing', caption: 'Calendário' },
  { src: '/screen-avaliacoes.png', alt: 'Tela de avaliação pós-pescaria no iFishing', caption: 'Avaliação' },
];
---
<BaseLayout
  title="Baixar o iFishing"
  description="Baixe o iFishing na App Store (iPhone). Versão Android chegando em breve no Google Play. App para conectar pescadores e guias em todo o Brasil."
>
  <section class="bg-gradient-to-b from-brand-light to-white">
    <div class="container-page py-16 lg:py-20 text-center">
      <h1 class="text-4xl sm:text-5xl text-ink">Baixe o iFishing</h1>
      <p class="mt-3 max-w-xl mx-auto text-lg text-ink-muted">
        Já disponível pra iPhone — a versão Android chega em breve. Crie sua conta em menos de um minuto e veja os guias de pesca disponíveis na sua região.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-2xl mx-auto">
        <div class="rounded-card border border-surface-border bg-white p-6 flex flex-col items-center">
          <a
            href={SITE.app.appStoreUrl}
            target="_blank"
            rel="noopener"
            aria-label="Baixar o iFishing na App Store"
            class="inline-flex items-center gap-3 rounded-2xl bg-ink px-5 h-14 text-white transition hover:bg-black"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7" aria-hidden="true"><path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.24-.01-.36-.03-.214-.99.27-2.02.825-2.7.74-.91 1.99-1.62 3.022-1.97.24.01.48.03.677.05zM20.5 17.45c-.43.99-.94 1.99-1.62 2.84-.77.95-1.79 2.13-3.06 2.14-1.13.01-1.42-.7-3.01-.69-1.6.01-1.93.7-3.05.7-1.27.01-2.24-1.05-3.02-2-.78-.95-1.71-2.55-1.88-4.07-.19-1.7.09-3.46.78-4.71.6-1.09 1.7-2.05 2.97-2.05 1.16-.02 2.25.78 2.99.78.74 0 2.07-.96 3.5-.82.6.02 2.27.24 3.34 1.83-2.7 1.57-2.27 5.49-.21 6.65.55.3 1.26.5 2.27.3z"/></svg>
            <span class="flex flex-col text-left">
              <span class="text-[10px] uppercase tracking-wider opacity-70">Baixe na</span>
              <span class="font-display text-base font-extrabold leading-tight">App Store</span>
            </span>
          </a>
          <p class="mt-6 text-sm text-ink-muted">ou aponte a câmera pro QR code</p>
          <img src="/qr-appstore.png" alt="QR code para baixar o iFishing na App Store" width="160" height="160" class="mt-3 h-40 w-40 rounded-lg bg-white p-2 ring-1 ring-surface-border" />
        </div>
        <div class="relative overflow-hidden rounded-card border border-surface-border bg-white p-6 flex flex-col items-center">
          <span
            class="pointer-events-none absolute right-[-44px] top-7 rotate-45 select-none bg-warning px-12 py-1 text-xs font-display font-extrabold uppercase tracking-widest text-white shadow-sm"
          >
            Em breve
          </span>
          <div
            aria-label="iFishing no Google Play — em breve"
            class="inline-flex items-center gap-3 rounded-2xl bg-ink px-5 h-14 text-white opacity-50 grayscale cursor-not-allowed"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
              <path fill="#34D399" d="M3.6 2.3 13.5 12 3.6 21.7c-.4-.3-.6-.8-.6-1.4V3.7c0-.6.2-1.1.6-1.4z"/>
              <path fill="#F59E0B" d="m17.5 8.2-3.1-1.8L4 2.3 13.5 12z"/>
              <path fill="#DC2626" d="M17.5 15.8 4 21.7 13.5 12z"/>
              <path fill="#60A5FA" d="m21 12-3.5-3.8L13.5 12l4 4z"/>
            </svg>
            <span class="flex flex-col text-left">
              <span class="text-[10px] uppercase tracking-wider opacity-70">Disponível no</span>
              <span class="font-display text-base font-extrabold leading-tight">Google Play</span>
            </span>
          </div>
          <p class="mt-6 text-sm font-medium text-ink">Chegando em breve para Android</p>
          <p class="mt-1 max-w-[16rem] text-center text-sm text-ink-muted">A versão Android está em revisão na Google Play. Enquanto isso, baixe pelo iPhone.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <h2 class="text-3xl text-ink">Por dentro do app</h2>
    <p class="mt-3 max-w-2xl text-ink-muted">Uma volta rápida pelas telas principais do iFishing.</p>
    <div class="mt-8 grid gap-6 sm:gap-8 grid-cols-2 sm:grid-cols-3 lg:grid-cols-6">
      {screenshots.map((s) => (
        <figure class="flex flex-col items-center">
          <div class="relative w-full rounded-[1.75rem] bg-ink p-1.5 shadow-card">
            <img
              src={s.src}
              alt={s.alt}
              loading="lazy"
              decoding="async"
              class="w-full rounded-[1.4rem]"
            />
          </div>
          <figcaption class="mt-3 text-sm font-medium text-ink-muted">{s.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>
