---
import BaseLayout from '~/layouts/BaseLayout.astro';
import StoreBadges from '~/components/StoreBadges.astro';
import { SITE } from '~/lib/site';

const steps = [
  {
    svg: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
    title: 'Lance a isca',
    text: 'Busque guias por nome, cidade e estado ou no mapa. Tem profissional em todo o Brasil.',
  },
  {
    svg: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
    title: 'Fisgue o guia',
    text: 'Converse pelo chat, tire dúvidas e veja se é o profissional certo pra você.',
  },
  {
    svg: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
    title: 'Amarre a pescaria',
    text: 'Reserve a data direto pelo calendário do guia. Rápido e sem conflito.',
  },
  {
    svg: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
    title: 'Conte a história',
    text: 'Avalie depois da pescaria e ajude outros pescadores a escolher bem.',
  },
];

const features = [
  {
    title: 'Atendimento em todo o Brasil',
    text: 'De Norte a Sul: pescaria de tucunaré, dourado, robalo, pintado e muito mais.',
    svg: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  },
  {
    title: 'Guias verificados',
    text: 'Telefone validado por SMS e documento de identidade conferido pela nossa equipe (Carteira de Pesca Profissional, CPF ou RG). Procure o selo azul, é garantia de profissional real.',
    svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    title: 'Reservas organizadas',
    text: 'Cada pescaria fica registrada com data, número de pescadores e histórico de mensagens. Sem combinado perdido no WhatsApp.',
    svg: '<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>',
  },
  {
    title: 'Notificações em tempo real',
    text: 'Receba alertas de novas mensagens do guia e atualizações da reserva, mesmo com o app fechado.',
    svg: '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>',
  },
];
---
<BaseLayout description="O iFishing conecta pescadores a guias de pesca profissionais em todo o Brasil. Sua próxima fisgada começa aqui.">
  <Fragment slot="head">
    <link rel="preload" as="image" href="/screen-home.webp" fetchpriority="high" />
  </Fragment>
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-light to-white">
    <div class="container-page py-10 lg:py-16 grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="text-center lg:text-left">
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold text-brand-dark shadow-sm border border-brand/20">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
          App disponível em todo o Brasil
        </span>
        <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl text-ink">
          Guia certo, pescaria garantida.
        </h1>
        <p class="mt-5 max-w-xl text-lg text-ink-muted mx-auto lg:mx-0">
          Cada pescaria começa com a escolha certa de guia. O <strong class="text-ink font-semibold">{SITE.name}</strong> te ajuda a encontrar esse profissional em qualquer canto do Brasil, de graça, sem complicação e sem taxa nenhuma.
        </p>
        <div class="mt-8">
          <StoreBadges mobileCenter />
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-2 text-sm text-ink-muted">
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Chat e reserva no app</span>
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Avaliações reais</span>
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Guias com Selo Verificado</span>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[3/2] w-full rounded-card overflow-hidden ring-1 ring-surface-border shadow-card">
          <img
            src="/screen-home.webp"
            alt="Pescador no barco ao amanhecer com tucunaré saltando na água"
            class="h-full w-full object-cover"
            width="1536"
            height="1024"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-ink/[0.02] border-y border-surface-border">
    <div class="container-page py-12">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-brand-light px-3 py-1 text-xs font-semibold text-brand-dark">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
            Guias verificados em todo o Brasil
          </span>
          <h2 class="mt-4 text-3xl sm:text-4xl text-ink">Encontre o guia certo pra você</h2>
          <p class="mt-3 text-lg text-ink-muted">Busque por nome, cidade ou espécie. Use o mapa pra descobrir guias próximos da sua região. Compare perfis com avaliações reais e fotos das pescarias antes de reservar.</p>
          <ul class="mt-6 space-y-3">
            {[
              'Filtros por preço, avaliação mínima e espécie',
              'Mapa interativo com guias por região',
              'Perfis com galeria, bio e avaliações reais',
            ].map((item) => (
              <li class="flex items-center gap-2 text-ink-muted">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 text-brand"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="flex justify-center gap-4 sm:gap-6">
          <div class="relative w-full max-w-[180px] rounded-[2.5rem] bg-ink p-2 shadow-card">
            <img src="/screen-busca3.webp" alt="Tela de busca do iFishing com lista de guias de pesca e fotos de pescaria" width="852" height="1846" loading="eager" decoding="async" class="w-full rounded-[2rem]" />
          </div>
          <div class="relative w-full max-w-[180px] rounded-[2.5rem] bg-ink p-2 shadow-card">
            <img src="/screen-mapa.webp" alt="Mapa do Brasil com pins de guias do iFishing em diferentes regiões" width="1320" height="2868" loading="lazy" decoding="async" class="w-full rounded-[2rem]" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-12">
    <div class="max-w-2xl">
      <h2 class="text-3xl sm:text-4xl text-ink">Como funciona</h2>
      <p class="mt-3 text-ink-muted text-lg">Quatro passos pra reservar sua próxima pescaria.</p>
    </div>
    <ol class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <li class="rounded-card border border-surface-border bg-white p-6 hover:shadow-card transition text-center">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-brand-light text-brand">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={step.svg} />
          </span>
          <p class="mt-3 text-xs font-semibold text-brand-dark uppercase tracking-wider">Passo {i + 1}</p>
          <h3 class="mt-1 text-lg text-ink">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{step.text}</p>
        </li>
      ))}
    </ol>
    <div class="mt-6 text-center">
      <a href="/como-funciona" class="text-sm font-semibold text-brand hover:underline">Ver o passo a passo completo →</a>
    </div>
  </section>

  <section class="bg-ink/[0.02] border-y border-surface-border">
    <div class="container-page py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f) => (
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={f.svg} />
            </span>
          </div>
          <h3 class="text-xl text-ink">{f.title}</h3>
          <p class="mt-2 text-ink-muted">{f.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-brand">
    <div class="container-page py-10 text-center text-white">
      <p class="text-xs font-semibold uppercase tracking-widest opacity-80">Diferencial iFishing</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-display font-extrabold">O único app de pesca 100% gratuito</h2>
      <p class="mt-4 max-w-xl mx-auto text-lg opacity-90">Sem taxa, sem comissão, sem mensalidade. Gratuito para pescadores. Gratuito para guias. Sempre.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-8 text-sm font-semibold opacity-90">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><polyline points="20 6 9 17 4 12"/></svg>
          Cadastro de guia gratuito
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><polyline points="20 6 9 17 4 12"/></svg>
          Nenhuma comissão por reserva
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><polyline points="20 6 9 17 4 12"/></svg>
          App gratuito para pescadores
        </span>
      </div>
    </div>
  </section>

  <section class="container-page py-12">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-brand-light px-3 py-1 text-xs font-semibold text-brand-dark">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
          Muito além da reserva
        </span>
        <h2 class="mt-4 text-3xl sm:text-4xl text-ink">As ferramentas que guia e pescador precisam, num só lugar</h2>
        <ul class="mt-6 space-y-4">
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
            </span>
            <div>
              <p class="font-semibold text-ink">Pontos de pesca</p>
              <p class="mt-1 text-sm text-ink-muted">Marque capturas, cevas e pontos especiais no mapa com foto e nota. 100% privado, só você vê seus pontos.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </span>
            <div>
              <p class="font-semibold text-ink">Atividade dos peixes (solunar)</p>
              <p class="mt-1 text-sm text-ink-muted">Índice diário de 0 a 100 com gráfico por hora, períodos maiores e menores, fase da lua, nascer e pôr do sol e da lua. Para qualquer cidade do Brasil.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/></svg>
            </span>
            <div>
              <p class="font-semibold text-ink">Meteorologia hora a hora</p>
              <p class="mt-1 text-sm text-ink-muted">Consulte o tempo de qualquer ponto de pesca do Brasil: temperatura, vento, chuva, pressão e índice UV hora a hora, com previsão de até 7 dias.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <p class="font-semibold text-ink">Mapa de guias</p>
              <p class="mt-1 text-sm text-ink-muted">Descubra guias próximos de você no mapa interativo com pins por região em todo o Brasil.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-light text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </span>
            <div>
              <p class="font-semibold text-ink">Chat em tempo real</p>
              <p class="mt-1 text-sm text-ink-muted">Converse com o guia direto no app, com confirmação de leitura, indicador de digitando e resposta a mensagens específicas.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="flex justify-center gap-4 sm:gap-6">
        <div class="relative w-full max-w-[160px] rounded-[2.5rem] bg-ink p-2 shadow-card">
          <img src="/screen-pontos.webp" alt="Tela de pontos de pesca com mapa satélite e opção de marcar local no iFishing" width="1320" height="2868" loading="lazy" decoding="async" class="w-full rounded-[2rem]" />
        </div>
        <div class="relative w-full max-w-[160px] rounded-[2.5rem] bg-ink p-2 shadow-card">
          <img src="/screen-solunar.webp" alt="Tela de atividade dos peixes com índice solunar e gráfico por hora no iFishing" width="736" height="1600" loading="lazy" decoding="async" class="w-full rounded-[2rem]" />
        </div>
        <div class="relative w-full max-w-[160px] rounded-[2.5rem] bg-ink p-2 shadow-card">
          <img src="/screen-meteo.webp" alt="Tela de meteorologia com condições atuais e previsão hora a hora no iFishing" width="736" height="1600" loading="lazy" decoding="async" class="w-full rounded-[2rem]" />
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-12">
    <div class="rounded-card bg-gradient-to-br from-brand to-brand-dark text-white p-8 lg:p-10 flex flex-col lg:flex-row lg:items-center justify-between gap-6 shadow-card">
      <div>
        <h2 class="text-3xl sm:text-4xl">Você é guia de pesca?</h2>
        <p class="mt-3 max-w-xl text-white/90">Apareça pra pescadores do Brasil todo. Agenda integrada, perfil profissional e clientes verificados.</p>
      </div>
      <a href="/para-guias" class="btn-primary !bg-white !text-brand-dark hover:!bg-brand-light shrink-0">Quero ser guia</a>
    </div>
  </section>

  <section class="container-page py-12 text-center">
    <h2 class="text-3xl sm:text-4xl text-ink">Bora marcar a data.</h2>
    <p class="mt-3 text-ink-muted text-lg max-w-xl mx-auto">Encontre o guia certo, reserve a data e organize tudo pelo app. Gratuito para pescadores e guias, sem taxa e sem comissão.</p>
    <div class="mt-6 flex justify-center">
      <StoreBadges align="center" />
    </div>
  </section>
</BaseLayout>
