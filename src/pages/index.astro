---
import BaseLayout from '~/layouts/BaseLayout.astro';
import StoreBadges from '~/components/StoreBadges.astro';
import { SITE } from '~/lib/site';

const steps = [
  {
    icon: 'search',
    title: 'Busque',
    text: 'Filtre guias por cidade, espécie-alvo ou veja o mapa interativo. Cobertura nacional.',
  },
  {
    icon: 'message',
    title: 'Converse',
    text: 'Chat 1-on-1 direto no app. Tire dúvidas sobre roteiro, equipamento e logística.',
  },
  {
    icon: 'calendar',
    title: 'Reserve',
    text: 'Calendário do guia em tempo real. Sem disponibilidade conflitante, sem dor de cabeça.',
  },
  {
    icon: 'star',
    title: 'Pesque e avalie',
    text: 'Curta a pescaria e, no fim, deixe sua avaliação pra ajudar a próxima galera.',
  },
];

interface Feature {
  title: string;
  text: string;
  badge?: string;
}

const features: Feature[] = [
  {
    title: 'Atendimento em todo o Brasil',
    text: 'De Norte a Sul: pescaria de tucunaré, dourado, robalo, pintado e muito mais.',
  },
  {
    title: 'Guias verificados',
    text: 'Telefone validado por SMS, perfil completo com bio, embarcação e galeria de fotos. Sem perfil vazio ou sem identidade.',
  },
  {
    title: 'Reservas organizadas',
    text: 'Cada pescaria fica registrada com data, número de pescadores e histórico de mensagens. Sem combinado perdido no WhatsApp.',
  },
  {
    title: 'Pagamento no app',
    text: 'Pix e cartão de crédito ou débito direto na reserva. Mais segurança pra pescador e pra guia.',
    badge: 'Em breve',
  },
];

---
<BaseLayout description="O iFishing conecta pescadores a guias de pesca profissionais em todo o Brasil. Sua próxima fisgada começa aqui.">
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-light to-white">
    <div class="container-page py-16 lg:py-24 grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold text-brand-dark shadow-sm border border-brand/20">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
          App disponível em todo o Brasil
        </span>
        <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl text-ink">
          Sua próxima fisgada<br/>começa aqui.
        </h1>
        <p class="mt-5 max-w-xl text-lg text-ink-muted">
          O <strong class="text-ink font-semibold">{SITE.name}</strong> conecta pescadores a guias de pesca profissionais espalhados pelo Brasil. Busque, converse, reserve e bora pescar.
        </p>
        <div class="mt-8">
          <StoreBadges />
        </div>
        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-muted">
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Chat e reserva no app</span>
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Avaliações reais</span>
          <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><polyline points="20 6 9 17 4 12"/></svg> Telefone verificado</span>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[3/2] w-full rounded-card overflow-hidden ring-1 ring-surface-border shadow-card">
          <img
            src="/screen-home.png"
            alt="Pescador no barco ao amanhecer com tucunaré saltando na água"
            class="h-full w-full object-cover"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="max-w-2xl">
      <h2 class="text-3xl sm:text-4xl text-ink">Como funciona</h2>
      <p class="mt-3 text-ink-muted text-lg">Quatro passos pra reservar sua próxima pescaria.</p>
    </div>
    <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <li class="rounded-card border border-surface-border bg-white p-6 shadow-card/0 hover:shadow-card transition">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-light text-brand-dark font-display font-extrabold">{i + 1}</span>
          <h3 class="mt-4 text-lg text-ink">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{step.text}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="bg-ink/[0.02] border-y border-surface-border">
    <div class="container-page py-20 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f) => (
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <h3 class="text-xl text-ink">{f.title}</h3>
            {f.badge && (
              <span class="inline-flex items-center rounded-full bg-brand px-2.5 py-0.5 text-xs font-bold text-white uppercase tracking-wider">{f.badge}</span>
            )}
          </div>
          <p class="mt-2 text-ink-muted">{f.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page py-20">
    <div class="rounded-card bg-gradient-to-br from-brand to-brand-dark text-white p-10 lg:p-14 flex flex-col lg:flex-row lg:items-center justify-between gap-8 shadow-card">
      <div>
        <h2 class="text-3xl sm:text-4xl">Você é guia de pesca?</h2>
        <p class="mt-3 max-w-xl text-white/90">Apareça pra pescadores do Brasil todo. Agenda integrada, perfil profissional e clientes verificados.</p>
      </div>
      <a href="/para-guias" class="btn-primary !bg-white !text-brand-dark hover:!bg-brand-light shrink-0">Quero ser guia</a>
    </div>
  </section>

  <section class="container-page py-20 text-center">
    <h2 class="text-3xl sm:text-4xl text-ink">Bora?</h2>
    <p class="mt-3 text-ink-muted text-lg max-w-xl mx-auto">Baixe o iFishing e organize sua próxima pescaria em minutos.</p>
    <div class="mt-8 flex justify-center">
      <StoreBadges align="center" />
    </div>
  </section>
</BaseLayout>
