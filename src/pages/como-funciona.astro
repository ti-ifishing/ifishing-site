---
import BaseLayout from '~/layouts/BaseLayout.astro';
import StoreBadges from '~/components/StoreBadges.astro';

interface Image {
  src: string;
  alt: string;
}

interface Section {
  eyebrow: string;
  title: string;
  body: string;
  points: string[];
  images?: Image[];
}

const sections: Section[] = [
  {
    eyebrow: '1 · Busca',
    title: 'Encontre o guia certo pra sua pescaria',
    body: 'Pesquise por cidade, região ou espécie-alvo. Use o mapa pra ver guias próximos da sua localização. Cada perfil tem foto, bio, embarcação, modalidades, galeria e avaliações reais de outros pescadores.',
    points: [
      'Filtros por preço, avaliação mínima e espécie',
      'Mapa interativo com guias próximos',
      'Previsão do tempo no ponto de pesca de cada guia',
      'Favoritar guias para acesso rápido',
      'Galeria de fotos das pescarias do guia',
      'Avaliações ordenadas por relevância',
    ],
    images: [
      { src: '/screen-busca3.png', alt: 'Tela de busca do iFishing com lista de guias e suas fotos de pesca' },
      { src: '/screen-mapa.png', alt: 'Mapa do Brasil com pins indicando guias do iFishing em diferentes regiões' },
    ],
  },
  {
    eyebrow: '2 · Chat',
    title: 'Converse antes de fechar',
    body: 'Chat em tempo real direto no app. Combine roteiro, equipamento, ponto de encontro e tudo mais, com recursos que você já conhece do WhatsApp.',
    points: [
      'Mensagens em tempo real com confirmação de leitura',
      'Responder e copiar mensagens (segure a mensagem)',
      'Indicador de "digitando"',
      'Foto do contato abre em tela cheia',
      'Histórico mantido pra consulta',
    ],
    images: [{ src: '/screen-chat.png', alt: 'Tela de chat 1-on-1 entre pescador e guia no iFishing' }],
  },
  {
    eyebrow: '3 · Reserva',
    title: 'Calendário sem conflito',
    body: 'A agenda do guia é atualizada em tempo real. Você só consegue reservar datas disponíveis, sem o vai-e-vem de mensagens pra descobrir se "o dia X tá livre".',
    points: [
      'Reserva de 1 ou mais dias',
      'Lembretes automáticos na véspera e no dia',
      'Cancelamento com motivo registrado',
    ],
    images: [{ src: '/screen-calendario.png', alt: 'Tela de calendário do guia com datas disponíveis e bloqueadas no iFishing' }],
  },
  {
    eyebrow: '4 · Avaliação',
    title: 'Pesque e ajude a próxima galera',
    body: 'Terminou a pescaria? Deixe sua avaliação em estrelas e texto. Suas notas ajudam outros pescadores a escolher melhor e mantêm os guias no nível.',
    points: [
      'Avaliação estrelas + comentário',
      'Resposta pública do guia',
      'Moderação contra avaliações abusivas',
    ],
    images: [{ src: '/screen-avaliacoes.png', alt: 'Tela de avaliação pós-pescaria com estrelas e comentário no iFishing' }],
  },
];

---
<BaseLayout
  title="Como funciona"
  description="Encontre guias de pesca profissionais em todo o Brasil, converse por chat, reserve no calendário e avalie a pescaria. Veja como funciona o iFishing."
>
  <section class="container-page py-16">
    <h1 class="text-sm font-semibold text-brand-dark uppercase tracking-wider">Como funciona</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-muted">
      Quatro passos pra você sair do nada pra uma pescaria reservada com guia profissional em qualquer canto do Brasil.
    </p>
  </section>

  <section class="container-page pb-20 space-y-20">
    {sections.map((s, i) => (
      <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
        <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
          <p class="text-xs font-bold text-brand uppercase tracking-widest">{s.eyebrow}</p>
          <h2 class="mt-2 text-3xl text-ink">{s.title}</h2>
          <p class="mt-3 text-ink-muted text-lg">{s.body}</p>
          <ul class="mt-5 space-y-2">
            {s.points.map((p) => (
              <li class="flex items-start gap-2 text-ink">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 h-4 w-4 shrink-0 text-brand"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
          {s.images && s.images.length > 0 ? (
            <div class:list={[
              'flex justify-center',
              s.images.length > 1 ? 'gap-4 sm:gap-6' : '',
            ]}>
              {s.images.map((img) => (
                <div class:list={[
                  'relative rounded-[2.5rem] bg-ink p-2 shadow-card w-full',
                  s.images!.length > 1 ? 'max-w-[200px]' : 'max-w-[280px]',
                ]}>
                  <img
                    src={img.src}
                    alt={img.alt}
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-[2rem]"
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="aspect-[4/5] max-w-sm mx-auto rounded-card bg-ink/5 ring-1 ring-surface-border flex items-center justify-center text-ink-muted text-sm">
              <span class="text-center px-6">Screenshot do app<br/><span class="text-xs">(placeholder)</span></span>
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <section class="container-page py-20 text-center">
    <h2 class="text-3xl text-ink">Pronto pra fisgar?</h2>
    <p class="mt-3 text-ink-muted max-w-xl mx-auto">Baixe o iFishing e veja os guias disponíveis na sua região.</p>
    <div class="mt-8 flex justify-center"><StoreBadges align="center" /></div>
  </section>
</BaseLayout>
