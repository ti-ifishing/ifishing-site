---
import { SITE } from '~/lib/site';

interface Props {
  kind: 'guide' | 'chat';
  label: string;
  subtitle: string;
}

const { kind, label, subtitle } = Astro.props;
---
<section class="container-page py-16 lg:py-24">
  <div class="mx-auto max-w-xl text-center">
    <span class="inline-flex items-center gap-2 rounded-full bg-brand-light px-3 py-1 text-xs font-semibold text-brand-dark">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
      {kind === 'guide' ? 'Perfil de guia' : 'Conversa'}
    </span>
    <h1 class="mt-4 text-3xl sm:text-4xl text-ink">{label}</h1>
    <p class="mt-3 text-ink-muted">{subtitle}</p>

    <div class="mt-8 rounded-card border border-surface-border bg-white p-6 text-left">
      <p class="text-sm font-semibold text-ink">Abra no app pra continuar</p>
      <p class="mt-1 text-sm text-ink-muted">
        Esta página é um link especial. Se você tem o iFishing instalado, ela abre direto no app.
        Senão, instale primeiro e tente de novo.
      </p>
      <div class="mt-5 flex flex-col gap-3">
        <a id="open-in-app" href="#" class="btn-primary w-full">Abrir no iFishing</a>
        <div class="flex flex-col sm:flex-row gap-3">
          <a class="btn-secondary flex-1" href={SITE.app.appStoreUrl} target="_blank" rel="noopener">App Store</a>
          <div class="relative flex-1">
            <span class="pointer-events-none absolute -top-2.5 left-1/2 -translate-x-1/2 z-10 whitespace-nowrap rounded-full bg-warning px-2 py-0.5 text-[10px] font-display font-extrabold uppercase tracking-wider text-white shadow-sm">
              Em breve
            </span>
            <div class="btn-secondary w-full text-center opacity-50 grayscale cursor-not-allowed" aria-label="Google Play — em breve">Google Play</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ kind, siteUrl: SITE.url }}>
  (function () {
    const path = window.location.pathname;
    const link = document.getElementById('open-in-app');

    // Extrai o ID do path (/guide/{id} ou /chat/{...slug}) e monta deep link
    const guideMatch = path.match(/^\/guide\/([^/]+)/);
    const chatMatch = path.match(/^\/chat\/(.+)/);
    let deepLink = null;
    if (guideMatch) deepLink = 'ifishing://guide/' + guideMatch[1];
    else if (chatMatch) deepLink = 'ifishing://chat/' + chatMatch[1];

    if (link && deepLink) {
      link.setAttribute('href', deepLink);
    }

    if (!deepLink) return;

    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (!isMobile) return;

    // Mobile: tenta abrir o app; se não abrir em ~2s, vai pra /baixar.
    let appOpened = false;
    const onVisibilityChange = () => {
      if (document.hidden) appOpened = true;
    };
    document.addEventListener('visibilitychange', onVisibilityChange);

    window.location.href = deepLink;

    setTimeout(() => {
      document.removeEventListener('visibilitychange', onVisibilityChange);
      if (!appOpened && !document.hidden) {
        window.location.href = '/baixar/';
      }
    }, 2200);
  })();
</script>
