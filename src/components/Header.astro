---
import { SITE } from '~/lib/site';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/como-funciona', label: 'Como funciona' },
  { href: '/para-guias', label: 'Sou guia' },
  { href: '/baixar', label: 'Baixar app' },
  { href: '/contato', label: 'Contato' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 border-b border-surface-border/70 bg-white/80 backdrop-blur">
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2" aria-label={`${SITE.name}, voltar à página inicial`}>
      <img src="/ifishing-icon.png" alt="" height="36" width="36" class="h-9 w-9 rounded-lg" />
      <span class="font-display text-xl font-extrabold tracking-tight text-ink">iFishing</span>
    </a>
    <nav aria-label="Principal" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {nav.map((item) => {
          const active = pathname === item.href;
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'rounded-full px-4 py-2 text-sm font-medium transition',
                  active
                    ? 'bg-brand-light text-brand-dark'
                    : 'text-ink-muted hover:text-ink hover:bg-surface-border/40',
                ]}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
    <details class="md:hidden">
      <summary class="list-none cursor-pointer rounded-full border border-surface-border p-2" aria-label="Abrir menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </summary>
      <div class="absolute left-0 right-0 top-16 border-b border-surface-border bg-white px-4 py-4">
        <ul class="flex flex-col gap-1">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="block rounded-lg px-3 py-2 text-sm font-medium text-ink hover:bg-surface-border/30">{item.label}</a>
            </li>
          ))}
          <li class="pt-2"><a href="/baixar" class="btn-primary w-full">Baixar agora</a></li>
        </ul>
      </div>
    </details>
  </div>
</header>
