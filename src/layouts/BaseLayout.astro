---
import '~/styles/global.css';
import { SITE } from '~/lib/site';
import SEO from '~/components/SEO.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, description, image, noindex, canonical } = Astro.props;

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.url,
      logo: `${SITE.url}/icon-1024.png`,
      sameAs: Object.values(SITE.social).filter(Boolean),
      contactPoint: {
        '@type': 'ContactPoint',
        email: SITE.supportEmail,
        contactType: 'customer support',
        areaServed: 'BR',
        availableLanguage: ['pt-BR'],
      },
    },
    {
      '@type': 'WebSite',
      name: SITE.name,
      url: SITE.url,
      description: SITE.description,
      inLanguage: 'pt-BR',
    },
  ],
};
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#18A348" />
    <link rel="icon" href="/favicon.ico?v=2" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-v2-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icon-v2-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@700;800&display=optional" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@700;800&display=optional" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@700;800&display=optional" /></noscript>
    <SEO {title} {description} {image} {noindex} {canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} is:inline />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-brand focus:px-3 focus:py-2 focus:text-white">Pular para o conteúdo</a>
    <div class="bg-brand text-white text-center text-xs sm:text-sm font-semibold py-2 px-4">
      iFishing é 100% gratuito para pescadores e guias, sem taxa, sem comissão, sem mensalidade.
    </div>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
