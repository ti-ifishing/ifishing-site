---
import BaseLayout from '~/layouts/BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <article class="container-prose py-16 lg:py-20">
    <header class="mb-10 pb-6 border-b border-surface-border">
      <h1 class="text-4xl text-ink">{title}</h1>
      <p class="mt-2 text-sm text-ink-muted">Última atualização: {lastUpdated}</p>
    </header>
    <div class="prose-legal space-y-6 text-ink/90 leading-relaxed">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-legal h2 {
    @apply mt-10 text-2xl text-ink;
  }
  .prose-legal h3 {
    @apply mt-6 text-lg text-ink;
  }
  .prose-legal p {
    @apply text-base;
  }
  .prose-legal ul {
    @apply list-disc pl-6 space-y-1;
  }
  .prose-legal ol {
    @apply list-decimal pl-6 space-y-1;
  }
  .prose-legal a {
    @apply text-brand-dark underline underline-offset-2 hover:text-brand;
  }
  .prose-legal strong {
    @apply font-semibold text-ink;
  }
</style>
